{
  "git.ignoreLimitWarning": true,
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venu\\Scripts\\python.exe",
  "python.terminal.useEnvFile": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.exclude": [
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.mypy_cache",
    "**/.ruff_cache",
    "**/.ipynb_checkpoints",
    "${workspaceFolder}/.venu",
    "${workspaceFolder}/.venv",
    "${workspaceFolder}/dashboard",
    "${workspaceFolder}/node_modules",
    "${workspaceFolder}/dist",
    "${workspaceFolder}/build",
    "${workspaceFolder}/logs",
    "${workspaceFolder}/reports",
    "${workspaceFolder}/artifacts",
    "${workspaceFolder}/outputs",
    "${workspaceFolder}/data",
    "${workspaceFolder}/models"
  ],
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.ipynb_checkpoints/**": true,
    "**/.venu/**": true,
    "**/.venv/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/logs/**": true,
    "**/reports/**": true,
    "**/artifacts/**": true,
    "**/outputs/**": true,
    "**/data/**": true,
    "**/models/**": true,
    "**/dashboard/**": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.ipynb_checkpoints": true,
    "**/.venu": true,
    "**/.venv": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/logs": true,
    "**/reports": true,
    "**/artifacts": true,
    "**/outputs": true,
    "**/data": true,
    "**/models": true,
    "**/dashboard": true
  }
}
